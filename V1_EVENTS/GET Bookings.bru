meta {
  name: GET Bookings
  type: http
  seq: 6
}

get {
  url: https://{{domain}}/api/v1/Bookings/10?$select=Event,SequenceNumber&$orderby=Event asc&search=EnteredOn gt DateTime'2026-03-01'
  body: none
  auth: inherit
}

params:query {
  $select: Event,SequenceNumber
  $orderby: Event asc
  search: EnteredOn gt DateTime'2026-03-01'
}

settings {
  encodeUrl: true
  timeout: 0
}
