meta {
  name: Momentus Enterprise API
}

auth {
  mode: bearer
}

auth:bearer {
  token: {{ungerboeck_jwt}}
}

script:pre-request {
  const crypto = require('crypto');
  
  function generateJWT() {
      const apiUserId = bru.getEnvVar("ApiUserID");
      const apiUserKey = bru.getEnvVar("ApiUserKey");
      const apiUserSecret = bru.getEnvVar("ApiUserSecret");
  
      const header = { alg: "HS256", typ: "JWT" };
      const now = Math.floor(Date.now() / 1000);
      
      const payload = {
          iss: apiUserId,
          key: apiUserKey,
          exp: now + 60, // IMPORTANTE: Dejamos esto como número, sin .toString()
          iat: now       // IMPORTANTE: Dejamos esto como número, sin .toString()
      };
  
      // Función auxiliar para codificar en Base64URL usando Buffer
      const base64url = (obj) => {
          return Buffer.from(JSON.stringify(obj))
              .toString('base64')
              .replace(/\+/g, '-')
              .replace(/\//g, '_')
              .replace(/=+$/, '');
      };
  
      const encodedHeader = base64url(header);
      const encodedPayload = base64url(payload);
      const tokenData = `${encodedHeader}.${encodedPayload}`;
  
      // Generar la firma usando el módulo nativo 'crypto' de Node.js
      const hmac = crypto.createHmac('sha256', apiUserSecret);
      const signature = hmac.update(tokenData).digest('base64')
          .replace(/\+/g, '-')
          .replace(/\//g, '_')
          .replace(/=+$/, '');
  
      const jwt = `${tokenData}.${signature}`;
      
      // Guardar la variable de entorno
      bru.setEnvVar("ungerboeck_jwt", jwt);
      console.log("JWT Generado:", jwt);
  }
  
  // Ejecutar la función
  generateJWT();
}

